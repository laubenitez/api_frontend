<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <div class="jumbotron">
            <h1>Clientes</h1>
            <table border="2px">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Teléfono</th>
                    </tr>
                </thead>
                <tbody>
                    <% clientes.forEach(function(cliente) { %>
                        <tr>
                            <td>
                                <%= cliente.nombre %>
                            </td>
                            <td>
                                <%= cliente.email %>
                            </td>
                            <td>
                                <%= cliente.telefono %>
                            </td>

                            <td>
                                <form action="/clientes/eliminar/<%= cliente.email %>" method="POST">
                                    <button type="submit">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
        </div>
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>

</html>